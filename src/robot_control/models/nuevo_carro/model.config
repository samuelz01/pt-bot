<?xml version="1.0"?>
<!-- Archivo de configuracion del modelo para Gazebo.
     Permite que Gazebo identifique y cargue el robot mecanum
     cuando se usa la directiva <include> con model://nuevo_modelo -->
<model>
  <name>nuevo_modelo</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>

  <author>
    <name>Samuel Perez</name>
    <email>samuel@todo.todo</email>
  </author>

  <description>
    Nuevo modelo mecanum con 4 ruedas omnidireccionales, sensor LIDAR y camara RGBD.
    Adaptado para el proyecto terminal de seguidor de linea con ROS 2 Jazzy.
  </description>
</model>
