<?xml version="1.0"?>
<!-- Archivo de configuracion del modelo para Gazebo.
     Permite que Gazebo identifique y cargue el robot mecanum
     cuando se usa la directiva <include> con model://nuevo_carro -->
<model>
  <name>nuevo_carro</name>
  <version>1.0</version>
  <sdf version="1.7">model.sdf</sdf>

  <author>
    <name>Samuel Perez</name>
    <email>samuel@todo.todo</email>
  </author>

  <description>
    Carro mecanum con 4 ruedas omnidireccionales, sensor LIDAR, IMU y camara RGBD.
    Preparado para co-simulacion ROS 2, Gazebo, MATLAB y Simulink.
  </description>
</model>
