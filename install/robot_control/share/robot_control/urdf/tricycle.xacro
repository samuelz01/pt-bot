<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tricycle_bot">

  <!-- ======================== -->
  <!-- Constantes de Geometría  -->
  <!-- ======================== -->
  <!-- Chasis físico principal para colisiones -->
  <xacro:property name="chassis_length" value="0.4"/>
  <xacro:property name="chassis_width" value="0.25"/>
  <xacro:property name="chassis_height" value="0.1"/>
  <xacro:property name="chassis_mass" value="2.0"/>
  
  <!-- Ruedas aumentadas y más realistas -->
  <xacro:property name="wheel_radius" value="0.08"/>
  <xacro:property name="wheel_thickness" value="0.035"/>
  <xacro:property name="wheel_mass" value="0.2"/>
  
  <xacro:property name="caster_radius" value="0.04"/>
  <xacro:property name="caster_mass" value="0.1"/>

  <!-- ======================== -->
  <!-- Macros de Inercia        -->
  <!-- ======================== -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (h*h + d*d)}" ixy="0.0" ixz="0.0" iyy="${(m/12) * (w*w + d*d)}" iyz="0.0" izz="${(m/12) * (w*w + h*h)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r h">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(m/12) * (3*r*r + h*h)}" ixy="0" ixz="0" iyy="${(m/12) * (3*r*r + h*h)}" iyz="0" izz="${(m/2) * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="sphere_inertia" params="m r">
    <inertial>
      <mass value="${m}"/>
      <inertia ixx="${(2/5) * m * (r*r)}" ixy="0.0" ixz="0.0" iyy="${(2/5) * m * (r*r)}" iyz="0.0" izz="${(2/5) * m * (r*r)}"/>
    </inertial>
  </xacro:macro>

  <!-- ======================== -->
  <!-- Base Footprint           -->
  <!-- ======================== -->
  <link name="base_footprint"/>

  <!-- ======================== -->
  <!-- Base Link (Chasis)       -->
  <!-- ======================== -->
  <joint name="base_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <!-- Elevamos el origen para que el fondo de las ruedas toque exactamente en Z=0 -->
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <link name="base_link">
    <!-- Visual 1: Plataforma base (Plateada) -->
    <visual>
      <origin xyz="${chassis_length/2} 0 ${chassis_height/4}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height/2}"/>
      </geometry>
      <material name="dark_grey">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    
    <!-- Visual 2: Carrocería / Cabina superior (Naranja) -->
    <visual>
      <origin xyz="${chassis_length/2 - 0.05} 0 ${chassis_height * 0.8}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length * 0.6} ${chassis_width * 0.8} ${chassis_height * 0.8}"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1"/>
      </material>
    </visual>
    
    <!-- Visual 3: Par de faros simulados al frente (Amarillos) -->
    <visual>
      <origin xyz="${chassis_length - 0.01} 0.08 ${chassis_height/2}" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.02"/>
      </geometry>
      <material name="yellow">
        <color rgba="1.0 1.0 0.0 1"/>
      </material>
    </visual>
    
    <visual>
      <origin xyz="${chassis_length - 0.01} -0.08 ${chassis_height/2}" rpy="0 1.5708 0"/>
      <geometry>
        <cylinder radius="0.02" length="0.02"/>
      </geometry>
      <material name="yellow">
        <color rgba="1.0 1.0 0.0 1"/>
      </material>
    </visual>

    <!-- La colisión sigue siendo un bloque único abstracto para proteger la física -->
    <collision>
      <origin xyz="${chassis_length/2} 0 ${chassis_height/2}" rpy="0 0 0"/>
      <geometry>
        <box size="${chassis_length} ${chassis_width} ${chassis_height}"/>
      </geometry>
    </collision>
    
    <xacro:box_inertia m="${chassis_mass}" w="${chassis_length}" d="${chassis_width}" h="${chassis_height}"/>
  </link>

  <!-- ======================== -->
  <!-- Rueda Izquierda          -->
  <!-- ======================== -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Un poco más separadas del chasis hacia los bordes -->
    <origin xyz="0.0 ${chassis_width/2 + wheel_thickness/2 + 0.01} 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <!-- Visual decorativo: Rin o tapón central (Blanco) -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius * 0.6}" length="${wheel_thickness + 0.01}"/>
      </geometry>
      <material name="white">
        <color rgba="0.9 0.9 0.9 1"/>
      </material>
    </visual>
    
    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_thickness}"/>
  </link>

  <gazebo reference="left_wheel">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <!-- ======================== -->
  <!-- Rueda Derecha            -->
  <!-- ======================== -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.0 ${-chassis_width/2 - wheel_thickness/2 - 0.01} 0" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
    <!-- Visual decorativo: Rin o tapón central (Blanco) -->
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius * 0.6}" length="${wheel_thickness + 0.01}"/>
      </geometry>
      <material name="white">
        <color rgba="0.9 0.9 0.9 1"/>
      </material>
    </visual>

    <collision>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" h="${wheel_thickness}"/>
  </link>

  <gazebo reference="right_wheel">
    <mu1 value="1.0"/>
    <mu2 value="1.0"/>
  </gazebo>

  <!-- ======================== -->
  <!-- Rueda Caster (Loca)      -->
  <!-- ======================== -->
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <!-- Alineación matemática para que toque el suelo exactamente igual que las ruedas -->
    <origin xyz="${chassis_length - caster_radius*2} 0 ${-(wheel_radius - caster_radius)}" rpy="0 0 0"/>
  </joint>

  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="grey_caster">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <xacro:sphere_inertia m="${caster_mass}" r="${caster_radius}"/>
  </link>

  <gazebo reference="caster_wheel">
    <!-- Cero fricción para que funcione como deslizador loco -->
    <mu1 value="0.0"/>
    <mu2 value="0.0"/>
  </gazebo>

  <!-- ======================== -->
  <!-- Cerebro Motor (Plugin)   -->
  <!-- ======================== -->
  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <!-- Nombres de las articulaciones de los motores -->
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      
      <!-- Físicas para que el plugin calcule los giros -->
      <wheel_separation>0.305</wheel_separation>
      <wheel_radius>${wheel_radius}</wheel_radius>
      
      <!-- Topic por el que escuchará dentro de Gazebo -->
      <topic>/cmd_vel</topic>
    </plugin>
  </gazebo>

  <!-- ======================== -->
  <!-- Sensor Cámara            -->
  <!-- ======================== -->
  <joint name="camera_joint" type="fixed">
    <parent link="base_link"/>
    <child link="camera_link"/>
    <!-- Colocada en la punta delantera del chasis. RPY de 1.2 rads = Apuntando ~70 grados hacia abajo -->
    <origin xyz="${chassis_length - 0.05} 0 ${chassis_height}" rpy="0 1.2 0"/>
  </joint>

  <link name="camera_link">
    <!-- Una pequeña caja negra representativa -->
    <visual>
      <geometry><box size="0.02 0.06 0.04"/></geometry>
      <material name="black">
        <color rgba="0.05 0.05 0.05 1"/>
      </material>
    </visual>
  </link>

  <gazebo reference="camera_link">
    <!-- El plugin nativo del sensor de cámara de Gazebo Harmonic -->
    <sensor name="line_camera" type="camera">
      <camera>
        <horizontal_fov>1.1</horizontal_fov>
        <image>
          <!-- Resolución óptima para no ahogar el procesador leyendo colores base -->
          <width>320</width>
          <height>240</height>
        </image>
        <clip>
          <near>0.05</near>
          <far>4.0</far>
        </clip>
      </camera>
      <always_on>1</always_on>
      <update_rate>30</update_rate> <!-- 30 FPS está volando para un seguidor simple -->
      <!-- Visualiza el cono azul transparente en pantalla -->
      <visualize>true</visualize>
      <topic>camera/image_raw</topic>
    </sensor>
  </gazebo>

</robot>
